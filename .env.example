# =========================================================================
# Promise Yura - Environment Configuration Template
# =========================================================================
# Copy this file to '.env' and fill in the active values for local use.
# Do NOT check actual API keys or secrets into public source control.

# -------------------------------------------------------------------------
# 🧠 Google Gemini AI Configuration
# -------------------------------------------------------------------------
# Required for YuraBrain natural language parsing and voice transcription interpretation.
# AI Studio automatically injects GEMINI_API_KEY at container boot runtime.
GEMINI_API_KEY="your_gemini_api_key_here"
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# -------------------------------------------------------------------------
# 🌐 Platform Application URL
# -------------------------------------------------------------------------
# The public/local URL hosting the current application frontend interface.
APP_URL="http://localhost:3000"

# -------------------------------------------------------------------------
# 🔥 Firebase Web Integration Configuration
# -------------------------------------------------------------------------
# These values can be extracted from your Firebase Console under Web App Settings.
# Once confirmed, initialize these inside your backend / dynamic configuration.
VITE_FIREBASE_API_KEY="your_firebase_api_key_here"
VITE_FIREBASE_AUTH_DOMAIN="your_firebase_auth_domain_here"
VITE_FIREBASE_PROJECT_ID="your_firebase_project_id_here"
VITE_FIREBASE_STORAGE_BUCKET="your_firebase_storage_bucket_here"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_firebase_messaging_sender_id_here"
VITE_FIREBASE_APP_ID="your_firebase_app_id_here"

# -------------------------------------------------------------------------
# 💬 Firebase Cloud Messaging (Web Push)
# -------------------------------------------------------------------------
# Public VAPID token Key for authenticating background service worker events
VITE_FIREBASE_VAPID_KEY="your_vapid_public_key_here"
