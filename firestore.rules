rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // The Invariant: check ownership
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidPromiseItem(data) {
      return data.keys().hasAll(['id', 'title', 'dateStr', 'timeStr', 'priority', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 500
        && data.dateStr is string && data.dateStr.size() <= 100
        && data.timeStr is string && data.timeStr.size() <= 100
        && data.priority is string && (data.priority == 'Low' || data.priority == 'Medium' || data.priority == 'High')
        && data.status is string && (data.status == 'upcoming' || data.status == 'needs check-in' || data.status == 'needs detail' || data.status == 'done' || data.status == 'missed')
        && (!data.keys().hasAny(['notes']) || (data.notes is string && data.notes.size() <= 2000))
        && (!data.keys().hasAny(['category']) || (data.category is string && data.category.size() <= 100))
        && (!data.keys().hasAny(['intensity']) || (data.intensity is string && (data.intensity == 'Gentle' || data.intensity == 'Normal' || data.intensity == 'Annoying')));
    }

    // Secure user paths
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /promises/{promiseId} {
        allow get: if isOwner(userId) && isValidId(promiseId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(promiseId) && isValidPromiseItem(request.resource.data);
        allow update: if isOwner(userId) && isValidId(promiseId) && isValidPromiseItem(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(promiseId);
      }

      match /fcmTokens/{token} {
        allow get, list, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.token is string && request.resource.data.token.size() <= 500
          && request.resource.data.createdAt is string && request.resource.data.createdAt.size() <= 100
          && request.resource.data.lastSeenAt is string && request.resource.data.lastSeenAt.size() <= 100
          && request.resource.data.userAgent is string && request.resource.data.userAgent.size() <= 1000;
      }
    }
  }
}
